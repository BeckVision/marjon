DJANGO_SECRET_KEY=your-secret-key-here
POSTGRES_DB=marjon_db
POSTGRES_USER=marjon
POSTGRES_PASSWORD=marjon_dev_password

# Moralis API keys (multiple for worker rotation)
MORALIS_API_KEY=
MORALIS_API_KEY_2=
MORALIS_API_KEY_3=
MORALIS_API_KEY_4=

# Optional: set this explicitly for your Moralis plan budget.
MORALIS_DAILY_CU_LIMIT=

# Shyft / Helius keys for RD-001
SHYFT_API_KEY_1=
HELIUS_API_KEY_1=

# Conservative RD-001 defaults for free-tier usage
MARJON_U001_DAILY_STEPS=discovery,pool_mapping,ohlcv
MARJON_U001_DAILY_COINS=50
MARJON_U001_DAILY_DAYS=20
MARJON_U001_DAILY_MATURE_ONLY=1
MARJON_U001_ENABLE_HOLDERS=0
MARJON_U001_HOLDERS_COINS=10
MARJON_U001_HOLDERS_DAYS=20
MARJON_U001_HOLDERS_MATURE_ONLY=1
MARJON_U001_RD001_MAX_COINS=25
MARJON_U001_RD001_ERROR_MAX_COINS=10
MARJON_U001_RD001_PARTIAL_MAX_COINS=10
MARJON_U001_RD001_PARTIAL_HIST_MAX_COINS=5
MARJON_U001_RD001_PARTIAL_GUARDED_MAX_COINS=1
MARJON_U001_RD001_MAX_NEW_SIGS=500
MARJON_U001_RD001_MAX_FILTERED_SIGNATURES=1000
MARJON_U001_RD001_BATCH_WORKERS=1
MARJON_U001_RD001_PARSE_WORKERS=1
MARJON_U001_RD001_RPC_BATCH_SIZE=100
MARJON_U001_RD001_MIN_SIGS=3
MARJON_U001_RD001_SLEEP=1.0
MARJON_HTTP2_DISABLED_HOSTS=api.shyft.to,rpc.shyft.to

# AWS credentials (for API Gateway rotation)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-southeast-2

# API Gateway proxy endpoints (6 regions for IP rotation)
GATEWAY_URL_1=https://xxxxx.execute-api.ap-southeast-2.amazonaws.com
GATEWAY_URL_2=https://xxxxx.execute-api.us-east-1.amazonaws.com
GATEWAY_URL_3=https://xxxxx.execute-api.eu-west-1.amazonaws.com
GATEWAY_URL_4=https://xxxxx.execute-api.ap-northeast-1.amazonaws.com
GATEWAY_URL_5=https://xxxxx.execute-api.us-west-2.amazonaws.com
GATEWAY_URL_6=https://xxxxx.execute-api.eu-central-1.amazonaws.com
